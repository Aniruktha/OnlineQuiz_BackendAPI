  "event": [
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Safe token storage - only runs after response is received",
          "if (pm.response && pm.request.url.path.includes('token') && pm.request.method === 'POST') {",
          "    let jsonData = {};",
          "    try { jsonData = pm.response.json(); } catch(e) {}",
          "    ",
          "    if (jsonData.access) {",
          "        // Check if it's admin login by checking request body",
          "        let body = pm.request.body ? pm.request.body.raw : '';",
          "        if (body && body.includes(pm.environment.get('admin_username'))) {",
          "            pm.collectionVariables.set('admin_token', jsonData.access);",
          "        } else {",
          "            pm.collectionVariables.set('user_token', jsonData.access);",
          "        }",
          "    }",
          "    if (jsonData.refresh) {",
          "        pm.collectionVariables.set('refresh_token', jsonData.refresh);",
          "    }",
          "}",
          "",
          "// Test response time",
          "pm.test('Response time < 2s', function() {",
          "    pm.expect(pm.response.responseTime).to.be.below(2000);",
          "});"
        ]
      }
    }
  ],
